---
import PattrnLayout from './PattrnLayout.astro';
import DocsNav from '../components/DocsNav.astro';
import SourceLink from '../components/SourceLink.astro';
import { getTopLevelKey } from '../lib/docs';

const { doc, frontmatter = {}, sourceUrl } = Astro.props;
const title = frontmatter.title ?? doc.title;
const description = frontmatter.description ?? `Pattrn documentation: ${doc.title}.`;
const current = getTopLevelKey(doc.section);
---
<PattrnLayout title={`${title} — Pattrn`} description={description} current={current}>
  <section class="page-heading narrow doc-heading">
    <p class="eyebrow">{doc.section}</p>
    <h1>{title}</h1>
    {frontmatter.description && <p class="lede">{frontmatter.description}</p>}
    <div class="actions">
      <SourceLink href={sourceUrl} />
    </div>
  </section>

  <section class="section doc-shell">
    <DocsNav currentRoute={doc.route} />
    <article class="doc-article">
      <div class="doc-content">
        <slot />
      </div>
    </article>
  </section>
</PattrnLayout>
