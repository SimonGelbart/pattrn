<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Pattrn.Strings</AssemblyName>
    <RootNamespace>Pattrn.Strings</RootNamespace>
    <PackageId>Pattrn.Strings</PackageId>
    <Authors>Simon Gelbart</Authors>
    <Description>Separated and dotted string helpers for Pattrn.</Description>
    <PackageTags>path;pattern;index;trie;wildcard;matching;strings;dotted;separated</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EnablePackageValidation>true</EnablePackageValidation>
    <IsAotCompatible>true</IsAotCompatible>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Pattrn\Pattrn.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\docs\packages\pattrn-strings.md" Pack="true" PackagePath="README.md" />
    <None Include="..\..\LICENSE.txt" Pack="true" PackagePath="\" />
    <None Include="..\..\assets\icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
