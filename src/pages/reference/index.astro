---
import PattrnLayout from '../../site/layouts/PattrnLayout.astro';
import { linkForSource, routeLink, type SiteLink } from '../../site/lib/docs';

type ReferenceGroup = {
  title: string;
  items: (SiteLink & { text: string })[];
};

const groups: ReferenceGroup[] = [
  {
    title: 'API and semantics',
    items: [
      { ...linkForSource('docs/reference/api.md', 'Core API'), text: 'Core public API map and entry points.' },
      { ...linkForSource('docs/reference/pattern-segments.md', 'Pattern segments'), text: 'Literal, parameter, wildcard, and catch-all segment model.' },
      { ...linkForSource('docs/reference/matching-semantics.md', 'Matching semantics'), text: 'What matches, why, and how detailed matching behaves.' },
      { ...linkForSource('docs/reference/ranking-specificity.md', 'Ranking and specificity'), text: 'Deterministic ranking metadata and specificity model.' },
      { ...linkForSource('docs/reference/compatibility-semantics.md', 'Compatibility semantics'), text: 'Compatibility posture for pre-beta evolution.' },
      { ...linkForSource('docs/reference/duplicate-behavior.md', 'Duplicate behavior'), text: 'Duplicate registration and materialization behavior.' },
      { ...linkForSource('docs/reference/diagnostics.md', 'Diagnostics'), text: 'Opt-in explanation APIs and rejection diagnostics.' },
      { ...linkForSource('docs/reference/limitations.md', 'Known limitations'), text: 'Current boundaries and intentionally unsupported behavior.' },
    ],
  },
  {
    title: 'Maintainer reference',
    items: [
      { ...linkForSource('docs/reference/project-profile.md', 'Project profile'), text: 'Durable public facts about Pattrn.' },
      { ...linkForSource('docs/reference/validation.md', 'Validation'), text: 'Validation posture and maintainer checks.' },
      { ...linkForSource('docs/reference/repository-layout.md', 'Repository layout'), text: 'Where code, docs, tests, and workflow assets live.' },
      { ...linkForSource('docs/reference/git-workflow.md', 'Git workflow'), text: 'Branch, commit, and remote operation guidance.' },
      { ...linkForSource('docs/reference/documentation-standards.md', 'Documentation standards'), text: 'Documentation ownership, curation, and staleness rules.' },
    ],
  },
  {
    title: 'Evidence',
    items: [
      { ...routeLink('/benchmarks/', 'Benchmarks'), text: 'Benchmark evidence policy and CI guardrail context.' },
    ],
  },
];
---
<PattrnLayout title="Pattrn reference" description="Reference map for Pattrn docs." current="reference">
  <section class="page-heading narrow">
    <p class="eyebrow">Reference</p>
    <h1>Stable reference map.</h1>
    <p class="lede">Use this curated map for API shape, matching behavior, maintainer guidance, and benchmark evidence. Current Markdown references render as styled project routes when they are part of the public route manifest.</p>
  </section>
  {groups.map((group) => (
    <section class="section">
      <div class="section-heading"><p class="eyebrow">Reference</p><h2>{group.title}</h2></div>
      <div class="doc-grid">
        {group.items.map((link) => (
          <a class="doc-link" href={link.href} rel={link.external ? 'noreferrer' : undefined}><strong>{link.label}{link.external ? ' ↗' : ''}</strong><p>{link.text}</p></a>
        ))}
      </div>
    </section>
  ))}
  <section class="section section-compact"><aside class="note"><p>This route remains a curated index. It highlights the reference paths reviewers need most instead of listing every rendered page.</p></aside></section>
</PattrnLayout>
