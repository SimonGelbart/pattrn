---
import PattrnLayout from '../../layouts/PattrnLayout.astro';
import { getRouteForSource, getSourceUrl, withBase } from '../../lib/docs';

function linkForSource(source: string) {
  const route = getRouteForSource(source);
  return route ? withBase(route) : getSourceUrl(source);
}

const groups = [
  { title: 'Start', text: 'Start here for the current user-facing path and the core mental model.', links: [['Core usage', `${getSourceUrl('README.md')}#core-usage`], ['Pattern segments', linkForSource('docs/reference/pattern-segments.md')], ['Matching semantics', linkForSource('docs/reference/matching-semantics.md')]] },
  { title: 'Understand', text: 'Use these when changing behavior, explaining tradeoffs, or reviewing compatibility.', links: [['Package boundaries', linkForSource('docs/explanation/package-boundaries.md')], ['Ranking and specificity', linkForSource('docs/reference/ranking-specificity.md')], ['Duplicate behavior', linkForSource('docs/reference/duplicate-behavior.md')], ['Diagnostics', linkForSource('docs/reference/diagnostics.md')]] },
  { title: 'Operate', text: 'Maintainer-oriented references for validation, evidence, and repository workflow.', links: [['Validation', linkForSource('docs/reference/validation.md')], ['Benchmarks', withBase('/benchmarks/')], ['Repository layout', linkForSource('docs/reference/repository-layout.md')]] },
  { title: 'Packages', text: 'Package-scoped README sources and companion-package guidance.', links: [['Core', linkForSource('docs/packages/pattrn.md')], ['Strings', linkForSource('docs/packages/pattrn-strings.md')], ['Dependency injection', linkForSource('docs/packages/pattrn-dependency-injection.md')], ['Routing', linkForSource('docs/packages/pattrn-routing.md')]] },
];
---
<PattrnLayout title="Pattrn docs" description="Curated documentation index for Pattrn." current="docs">
  <section class="page-heading narrow">
    <p class="eyebrow">Docs</p>
    <h1>Documentation by intent.</h1>
    <p class="lede">The Markdown files in <code>docs/**</code> remain the canonical project documentation. This route is a curated public index into the current docs path.</p>
  </section>
  <section class="section">
    <div class="grid grid--two">
      {groups.map((group) => (
        <article class="card">
          <p class="meta-line">{group.title}</p>
          <h2>{group.title}</h2>
          <p>{group.text}</p>
          <ul class="list-plain">
            {group.links.map(([label, href]) => <li><a class="text-link" href={href} rel="noreferrer">{label} ↗</a></li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
  <section class="section section-compact">
    <aside class="note callout"><p><strong>Migration note:</strong> this first Astro shell does not render every Markdown file as a styled route. The curated pages preserve the stable project URLs while keeping the repository docs canonical.</p></aside>
  </section>
</PattrnLayout>
