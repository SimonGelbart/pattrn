---
import PattrnLayout from '../../site/layouts/PattrnLayout.astro';
import { linkForSource, sourceLink, routeLink, type SiteLink } from '../../site/lib/docs';

const groups: { title: string; text: string; links: SiteLink[] }[] = [
  {
    title: 'Start',
    text: 'Begin with the current user-facing path, first index walkthrough, and core mental model.',
    links: [
      sourceLink('README.md#core-usage', 'Core usage'),
      linkForSource('docs/tutorials/first-index.md', 'Build your first index'),
      linkForSource('docs/reference/pattern-segments.md', 'Pattern segments'),
      linkForSource('docs/reference/matching-semantics.md', 'Matching semantics'),
    ],
  },
  {
    title: 'Understand',
    text: 'Use these when changing behavior, explaining tradeoffs, or reviewing compatibility.',
    links: [
      linkForSource('docs/explanation/package-boundaries.md', 'Package boundaries'),
      linkForSource('docs/reference/ranking-specificity.md', 'Ranking and specificity'),
      linkForSource('docs/reference/duplicate-behavior.md', 'Duplicate behavior'),
      linkForSource('docs/reference/diagnostics.md', 'Diagnostics'),
    ],
  },
  {
    title: 'Operate',
    text: 'Maintainer-oriented references for validation, evidence, and repository workflow.',
    links: [
      linkForSource('docs/reference/validation.md', 'Validation'),
      routeLink('/benchmarks/', 'Benchmarks'),
      linkForSource('docs/reference/repository-layout.md', 'Repository layout'),
      linkForSource('docs/reference/git-workflow.md', 'Git workflow'),
    ],
  },
  {
    title: 'Packages',
    text: 'Package-scoped docs and companion-package guidance.',
    links: [
      linkForSource('docs/packages/pattrn.md', 'Core'),
      linkForSource('docs/packages/pattrn-strings.md', 'Strings'),
      linkForSource('docs/packages/pattrn-dependency-injection.md', 'Dependency injection'),
      linkForSource('docs/packages/pattrn-routing.md', 'Routing'),
    ],
  },
];
---
<PattrnLayout title="Pattrn docs" description="Curated documentation index for Pattrn." current="docs">
  <section class="page-heading narrow">
    <p class="eyebrow">Docs</p>
    <h1>Documentation hub.</h1>
    <p class="lede">Markdown files in <code>docs/**</code> remain the canonical project documentation. Selected current docs render as styled project routes, while source links stay available for review and source-only material.</p>
  </section>
  <section class="section">
    <div class="grid grid--two">
      {groups.map((group) => (
        <article class="card">
          <p class="meta-line">{group.title}</p>
          <h2>{group.title}</h2>
          <p>{group.text}</p>
          <ul class="list-plain">
            {group.links.map((link) => <li><a class="text-link" href={link.href} rel={link.external ? 'noreferrer' : undefined}>{link.label}{link.external ? ' ↗' : ''}</a></li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
  <section class="section section-compact">
    <aside class="note callout"><p><strong>Curated route:</strong> this page is an intentional landing page for documentation paths, not a generated dump of every published route.</p></aside>
  </section>
</PattrnLayout>
