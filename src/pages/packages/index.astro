---
import PattrnLayout from '../../site/layouts/PattrnLayout.astro';
import { linkForSource, type SiteLink } from '../../site/lib/docs';

const packages: ({ name: string; role: string; status: string; text: string } & SiteLink)[] = [
  { name: 'Pattrn', role: 'Core package', status: 'Pre-beta stable candidate', text: 'Generic segmented-pattern matching, explicit PatternSegment registration, immutable compiled indexes, detailed matching, captures, ranking metadata, duplicate behavior, and optional diagnostics.', ...linkForSource('docs/packages/pattrn.md', 'Read package docs') },
  { name: 'Pattrn.Strings', role: 'String ergonomics', status: 'Pre-beta stable candidate', text: 'String splitting, separators, case sensitivity, trimming, empty segment behavior, normalization, and ergonomic string-path builders and indexes.', ...linkForSource('docs/packages/pattrn-strings.md', 'Read package docs') },
  { name: 'Pattrn.DependencyInjection', role: 'Application integration', status: 'Pre-beta stable candidate', text: 'Thin Microsoft.Extensions.DependencyInjection integration for registering compiled indexes as singletons and keeping application wiring framework-neutral.', ...linkForSource('docs/packages/pattrn-dependency-injection.md', 'Read package docs') },
  { name: 'Pattrn.Routing', role: 'Routing companion', status: 'Preview', text: 'Framework-neutral route-template parsing, structural route-template compilation, metadata preservation, optional/defaulted segment expansion, and route-layer validation. This package remains preview until explicitly stabilized.', ...linkForSource('docs/packages/pattrn-routing.md', 'Read package docs') },
];
---
<PattrnLayout title="Pattrn packages" description="Package family overview for Pattrn." current="packages">
  <section class="page-heading narrow">
    <p class="eyebrow">Packages</p>
    <h1>Package boundaries are part of the product.</h1>
    <p class="lede">Pattrn keeps the core matcher domain-neutral and moves syntax or integration concerns into focused companion packages. Package docs render as project routes from their canonical Markdown sources.</p>
  </section>
  <section class="section">
    <div class="package-list">
      {packages.map((pkg) => (
        <a class="package-row" href={pkg.href} rel={pkg.external ? 'noreferrer' : undefined}>
          <div class="package-row__meta"><span>{pkg.role}</span><strong>{pkg.status}</strong></div>
          <div><h2><code>{pkg.name}</code></h2><p>{pkg.text}</p><p class="meta-line">{pkg.label}{pkg.external ? ' ↗' : ''}</p></div>
        </a>
      ))}
    </div>
  </section>
  <section class="section section-compact"><aside class="note callout"><p><strong>Stability posture:</strong> pre-beta stable candidate means the package is being shaped toward beta readiness, not that the public API is frozen. <code>Pattrn.Routing</code> remains preview.</p></aside></section>
</PattrnLayout>
